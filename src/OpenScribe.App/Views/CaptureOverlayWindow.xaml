<Window
    x:Class="OpenScribe.App.Views.CaptureOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OpenScribe — Recording">

    <Grid x:Name="RootGrid" Padding="16,10" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Countdown or Recording indicator -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <!-- Countdown display -->
            <TextBlock x:Name="CountdownText"
                       Text="{Binding CountdownValue}"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource OpenScribeAccentBrush}"
                       Visibility="{Binding IsCountingDown, Converter={StaticResource BoolToVisibility}}"
                       VerticalAlignment="Center" />

            <!-- Recording dot -->
            <Ellipse Width="12" Height="12"
                     Fill="{StaticResource OpenScribeDangerBrush}"
                     VerticalAlignment="Center" />

            <TextBlock Text="REC" FontWeight="SemiBold" FontSize="13" Opacity="0.8"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Stats -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding ElapsedTime}"
                       FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="|" Opacity="0.3" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StepCount}"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text=" steps" Opacity="0.7" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Pause/Resume -->
        <Button Grid.Column="2" Margin="4,0"
                Command="{Binding TogglePauseCommand}"
                ToolTipService.ToolTip="Pause / Resume"
                VerticalAlignment="Center" Padding="8,6">
            <FontIcon x:Name="PauseResumeIcon" Glyph="&#xE769;" FontSize="14" />
        </Button>

        <!-- Stop -->
        <Button Grid.Column="3"
                Style="{StaticResource AccentButtonStyle}"
                Command="{Binding RequestStopCommand}"
                ToolTipService.ToolTip="Stop Recording"
                VerticalAlignment="Center" Padding="8,6">
            <FontIcon Glyph="&#xE71A;" FontSize="14" />
        </Button>
    </Grid>
</Window>
