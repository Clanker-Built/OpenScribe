<Page
    x:Class="OpenScribe.App.Views.CapturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OpenScribe.Core.Models">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Capture Process" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <!-- Settings -->
        <StackPanel Grid.Row="1" Spacing="12" Margin="0,0,0,16">
            <TextBox Header="Session Name"
                     PlaceholderText="e.g., How to submit a purchase order"
                     Text="{x:Bind ViewModel.SessionName, Mode=TwoWay}"
                     IsEnabled="{x:Bind ViewModel.IsCapturing, Mode=OneWay, Converter={StaticResource BoolNegation}}" />
            <CheckBox Content="Record microphone audio"
                      IsChecked="{x:Bind ViewModel.RecordAudio, Mode=TwoWay}"
                      IsEnabled="{x:Bind ViewModel.IsCapturing, Mode=OneWay, Converter={StaticResource BoolNegation}}" />

            <!-- Audio device picker + level meter (visible when RecordAudio is checked) -->
            <StackPanel Spacing="8" Margin="28,0,0,0"
                        Visibility="{x:Bind ViewModel.IsAudioDevicePickerVisible, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{x:Bind ViewModel.AvailableAudioDevices}"
                              SelectedItem="{x:Bind ViewModel.SelectedAudioDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              PlaceholderText="Select audio device"
                              MinWidth="300"
                              IsEnabled="{x:Bind ViewModel.IsCapturing, Mode=OneWay, Converter={StaticResource BoolNegation}}" />
                    <Button Command="{x:Bind ViewModel.RefreshAudioDevicesCommand}"
                            ToolTipService.ToolTip="Refresh audio devices"
                            IsEnabled="{x:Bind ViewModel.IsCapturing, Mode=OneWay, Converter={StaticResource BoolNegation}}">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE720;" FontSize="16" VerticalAlignment="Center" />
                    <ProgressBar Value="{x:Bind ViewModel.AudioLevel, Mode=OneWay}"
                                 Minimum="0" Maximum="100"
                                 Width="200" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
            <CheckBox Content="Record screen video"
                      IsChecked="{x:Bind ViewModel.RecordVideo, Mode=TwoWay}"
                      IsEnabled="{x:Bind ViewModel.IsCapturing, Mode=OneWay, Converter={StaticResource BoolNegation}}" />
        </StackPanel>

        <!-- Capture Scope -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,16"
                    IsHitTestVisible="{x:Bind ViewModel.IsCapturing, Mode=OneWay, Converter={StaticResource BoolNegation}}">
            <TextBlock Text="Capture Scope" FontWeight="SemiBold" />
            <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedScopeTypeIndex, Mode=TwoWay}"
                          MaxColumns="3">
                <RadioButton Content="Entire Screen (all monitors)" />
                <RadioButton Content="Specific Monitor" />
                <RadioButton Content="Specific Window" />
            </RadioButtons>

            <StackPanel Orientation="Horizontal" Spacing="8"
                        Visibility="{x:Bind ViewModel.IsMonitorScopeSelected, Mode=OneWay}">
                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableMonitors}"
                          SelectedItem="{x:Bind ViewModel.SelectedMonitor, Mode=TwoWay}"
                          PlaceholderText="Select a monitor"
                          MinWidth="300" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8"
                        Visibility="{x:Bind ViewModel.IsWindowScopeSelected, Mode=OneWay}">
                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableWindows}"
                          SelectedItem="{x:Bind ViewModel.SelectedWindow, Mode=TwoWay}"
                          PlaceholderText="Select a window"
                          MinWidth="400" />
            </StackPanel>

            <Button Content="Refresh"
                    Command="{x:Bind ViewModel.RefreshCaptureTargetsCommand}"
                    ToolTipService.ToolTip="Re-enumerate monitors and windows" />
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <Button Content="Start Recording"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.StartCaptureCommand}" />
            <Button Content="Pause"
                    Command="{x:Bind ViewModel.PauseCaptureCommand}" />
            <Button Content="Resume"
                    Command="{x:Bind ViewModel.ResumeCaptureCommand}" />
            <Button Content="Stop Recording"
                    Command="{x:Bind ViewModel.StopCaptureCommand}" />
            <Button Content="Manual Screenshot"
                    Command="{x:Bind ViewModel.CaptureManualScreenshotCommand}" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="24,0,0,0">
                <FontIcon Glyph="&#xE916;" FontSize="16" />
                <TextBlock Text="{x:Bind ViewModel.ElapsedTime, Mode=OneWay}" FontWeight="SemiBold" />
                <TextBlock Text="|" Opacity="0.3" />
                <TextBlock>
                    <Run Text="{x:Bind ViewModel.StepCount, Mode=OneWay}" />
                    <Run Text=" steps" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Captured Steps -->
        <ListView Grid.Row="4"
                  ItemsSource="{x:Bind ViewModel.CapturedSteps, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ProcessStep">
                    <Grid Padding="8" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind SequenceNumber}" FontWeight="Bold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{x:Bind WindowTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Opacity="0.6" FontSize="12">
                                <Run Text="Click at (" /><Run Text="{x:Bind ClickX}" /><Run Text="," /><Run Text="{x:Bind ClickY}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind Timestamp}" Opacity="0.6" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status -->
        <TextBlock Grid.Row="5" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Margin="0,8,0,0" />
    </Grid>
</Page>
